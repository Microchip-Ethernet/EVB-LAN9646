--- linux-linux4microchip-2024.04-old/drivers/net/dsa/microchip/ksz9477.c	2026-04-28 16:20:25.825393479 -0700
+++ linux-linux4microchip-2024.04-new/drivers/net/dsa/microchip/ksz9477.c	2026-04-28 16:23:43.901211514 -0700
@@ -1970,6 +1970,30 @@ int ksz9477_handle_irq(struct ksz_device
 }
 #endif
 
+void ksz9477_suspend(struct ksz_device *dev)
+{
+#ifndef CONFIG_SFP
+	if (ksz_has_sgmii_port(dev)) {
+		if (delayed_work_pending(&dev->sgmii_check))
+			cancel_delayed_work_sync(&dev->sgmii_check);
+	}
+#endif
+}
+
+void ksz9477_resume(struct ksz_device *dev)
+{
+#ifndef CONFIG_SFP
+	if (ksz_has_sgmii_port(dev)) {
+		int port = ksz_get_sgmii_port(dev);
+		struct ksz_port *p = &dev->ports[port];
+
+		if (sgmii_need_polling(dev, p))
+			schedule_delayed_work(&dev->sgmii_check,
+					      msecs_to_jiffies(500));
+	}
+#endif
+}
+
 MODULE_AUTHOR("Woojung Huh <Woojung.Huh@microchip.com>");
 MODULE_DESCRIPTION("Microchip KSZ9477 Series Switch DSA Driver");
 MODULE_LICENSE("GPL");
